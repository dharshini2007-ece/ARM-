void lcdcmd(unsigned char cmd)
{
    IOCLR1 =IOCLR1|(0xFF<<19);

    IOCLR1 = RS;   // RS = 0
    IOCLR1= RW;   // RW = 0
    IOSET1=((cmd&0xFF)<<19);
    IOSET1= EN;
    delay();
    IOCLR1 = EN;
}

// -------- LCD DATA FUNCTION --------
void lcddata(unsigned char dat)
{
	IOCLR1 =IOCLR1|(0xFF<<19);

    IOSET1 = RS;   // RS = 1
    IOCLR1 = RW;   // RW = 0
    IOSET1=((dat&0xFF)<<19);
    IOSET1 = EN;
    delay();
    IOCLR1 = EN;
}


// -------- SMALL DELAY --------
void delay() 
{
    unsigned int i;
    for(i=0;i<50000;i++);
}
